# ===== GenAI Recruiter Bot — environment variables =====
# Copy to .env and fill in. NEVER commit .env (spec N-6).

# --- OpenAI ---
OPENAI_API_KEY=replace-me


# --- Models (spec §5, configurable per N-2) ---
MAIN_AGENT_MODEL=gpt-4o-mini
ADVISOR_MODEL=gpt-4o-mini
EXIT_ADVISOR_FINETUNED_MODEL=            # set after Phase 3 (GRB-032); empty = prompted fallback
EMBEDDING_MODEL=text-embedding-3-small

# --- Behavior ---
DECISION_TEMPERATURE=0.0                 # routing/decisions (spec §5.1)
MESSAGE_TEMPERATURE=0.7                  # user-facing phrasing
MAX_ADVISOR_CONSULTS=3                   # guard R-1
RETRIEVAL_TOP_K=4                        # Info Advisor (spec §5.4)

# --- Paths & data ---
SQLITE_DB_PATH=data/tech.db
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION=job_description
JOB_DESCRIPTION_PDF=data/raw/Python_Developer_Job_Description.pdf
CONVERSATIONS_JSON=data/raw/sms_conversations.json

# --- Demo mode (risk #4: DB seeded for 2024) ---
DEMO_NOW_OVERRIDE=2024-04-15T10:00:00Z   # empty = wall clock

# --- Logging ---
LOG_LEVEL=INFO
